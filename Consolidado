WITH
CAUSA_RECHAZO AS (
  SELECT
    *
  FROM(
    SELECT 
      BR_SOLIC_CVE, 
      BR_TIPO, 
      BR_TASA_CVE, 
      BR_IMP_LIM_CRED_APROB, 
      BR_REGLA_CVE, 
      ROW_NUMBER() OVER(PARTITION BY BR_SOLIC_CVE, BR_TIPO ORDER BY CASE WHEN BR_FLUJO_CVE=7 THEN 999 ELSE BR_FLUJO_CVE END DESC) AS rn
    FROM crp-pro-dwh-semanticagold.EIL_DP_VDWH.VFAC_OMDM_FLUJO 
    WHERE FCH_CARGA >= '2024-01-01'
  )
  WHERE rn=1
),

VFAC_SDO_CTA_MES AS (
  SELECT
    *
  FROM (
    SELECT 
      a.*,
      b.CTA_FCH_ALTA,
      c.CTE_CVE_RFC,
      ROW_NUMBER() OVER (PARTITION BY a.CTA_CVE ORDER BY c.CTE_CVE_RFC DESC) AS rn
    FROM `crp-pro-dwh-semanticagold.EIL_DP_VDWH.VFAC_SDO_CTA_MES` a
    LEFT JOIN crp-pro-dwh-semanticagold.EIL_DP_VDWH.VDIM_CTA b
    ON a.CTA_CVE = b.CTA_CVE
    LEFT JOIN crp-pro-dwh-semanticagold.EIL_DP_VDWH.VDIM_CLIE_FTES c
    ON a.CTA_CVE = c.CTA_CVE
    WHERE a.ANIO >= 2023
  )
  WHERE rn=1
),

VFAC_SDO_CTA_MES_GRPD AS (
  SELECT 
    CTE_CVE_RFC,
    MAX(CASE WHEN TIP_INF=210 THEN CTA_CVE ELSE -999 END) AS CTA_TD,
    MAX(CASE WHEN TIP_INF=230 THEN CTA_CVE ELSE -999 END) AS CTA_Minipagos,
    MAX(CASE WHEN TIP_INF=200 THEN CTA_CVE ELSE -999 END) AS CTA_VISA,

    MIN(CASE WHEN TIP_INF=210 THEN CTA_FCH_ALTA ELSE '3000-12-31' END) AS FchAlta_TD,
    MIN(CASE WHEN TIP_INF=230 THEN CTA_FCH_ALTA ELSE '3000-12-31' END) AS FchAlta_Minipagos,
    MIN(CASE WHEN TIP_INF=200 THEN CTA_FCH_ALTA ELSE '3000-12-31' END) AS FchAlta_VISA,

    MIN(CASE WHEN TIP_INF IN (200,210,230) THEN CTA_FCH_ALTA ELSE '1900-01-01' END) AS FechaAperturaCuentaMasRecienteSBB,
    MIN(CASE WHEN TIP_INF IN (100,110) THEN CTA_FCH_ALTA ELSE '1900-01-01' END) AS FechaAperturaCuentaMasRecienteLIV,
    MAX(CTA_NIV_MOR) AS MaximaMoraActual,
    MAX(CASE WHEN CCR_CVE_BLQ_UNO='K' OR CCR_CVE_BLQ_DOS='K' THEN 1 ELSE 0 END) AS CuentaCastigada,
    MAX(CASE WHEN CCR_CVE_BLQ_UNO='A' OR CCR_CVE_BLQ_DOS='A' THEN 1 ELSE 0 END) AS CuentaAbogados,
    MIN(CASE WHEN CCR_CVE_BLQ_UNO='C' OR CCR_CVE_BLQ_DOS='C' THEN LEAST(CTA_FCH_BLQ_UNO,CTA_FCH_BLQ_DOS) ELSE '3000-12-31' END) AS FechaCancelacion
  FROM VFAC_SDO_CTA_MES
  GROUP BY 1
),

CONSOLIDADO AS (
  SELECT
    a.BR_SOLIC_CVE,
    a.BR_TIPO,
    a.BR_ORG,
    a.BR_FCH_APE,
    c.CTA_MISC_CR_SCORE,
    a.BR_HIT_DES,
    a.SegmentoScore,
    f.BR_RFC,
    g.CTA_TD,
    g.CTA_Minipagos,
    g.CTA_VISA,
    g.FchAlta_TD,
    g.FchAlta_Minipagos,
    g.FchAlta_VISA,
    CASE WHEN IF(a.PTI > 0.75, 'DECLINE', a.DECISION) IN ('QUASH','LÍNEA BAJA','APPROVE') THEN 'APPROVE' ELSE 'DECLINE' END AS DecisionTD,
    CASE WHEN a.PTI > 0.75 OR a.DECISION='DECLINE' THEN 0 ELSE a.RiskLevelTD END AS RiskLevelTD,
    CASE WHEN a.PTI > 0.75 OR a.DECISION='DECLINE' THEN 0 ELSE a.LCTD END AS LCTD,
    -- CASE WHEN a.PTI > 0.75 OR a.DECISION='DECLINE' THEN 0 ELSE a.TasaTD END AS TasaTD,
    IF(a.PTI > 0.75, 'DECLINE', b.DECISION2) AS DecisionMinipagos,
    CASE WHEN a.PTI > 0.75 OR a.DECISION='DECLINE' THEN 0 ELSE b.RiskLevelMinipagos END AS RiskLevelMinipagos,
    CASE WHEN a.PTI > 0.75 OR a.DECISION='DECLINE' THEN 0 ELSE b.LCMinipagos END AS LCMinipagos,
    IF(a.PTI > 0.75, 'DECLINE', c.MismaAprobacion) AS DecisionVISA,
    CASE WHEN a.PTI > 0.75 OR a.DECISION='DECLINE' THEN 0 ELSE c.RISK_LEVEL_ORG END AS RiskLevelVISA,
    CASE WHEN a.PTI > 0.75 OR a.DECISION='DECLINE' THEN 0 ELSE c.LC_FINAL_NEWSTR END AS LCVISA,
    -- CASE WHEN a.PTI > 0.75 OR a.DECISION='DECLINE' THEN 0 ELSE c.TASA END AS TasaVISA,
    -- d.BR_TASA_CVE AS TasaActual,
    e.BR_REGLA_DES,
    d.BR_IMP_LIM_CRED_APROB AS LineaActual,
    IF (d.BR_IMP_LIM_CRED_APROB > 0, 'APPROVE', 'DECLINE') AS DecisionActual
  FROM crp-sdx-negfin-analitica.mus_sdx_negfin_tbls_tmp.SBBTTD_ScoresTD a
  LEFT JOIN crp-sdx-negfin-analitica.mus_sdx_negfin_tbls_tmp.SBBTTD_ScoresMinipagos b
  USING(BR_SOLIC_CVE, BR_TIPO)
  LEFT JOIN crp-sdx-negfin-analitica.mus_sdx_negfin_tbls_tmp.SBBTTD_ScoresVISA c
  USING(BR_SOLIC_CVE, BR_TIPO)
  LEFT JOIN CAUSA_RECHAZO d
  USING(BR_SOLIC_CVE, BR_TIPO)
  LEFT JOIN crp-pro-dwh-semanticagold.EIL_DP_VDWH.VCIS_OMDM_REGLA e
  ON d.BR_REGLA_CVE=e.BR_REGLA_CVE
  LEFT JOIN crp-pro-dwh-semanticagold.EIL_DP_VDWH.VFAC_APIA f
  ON a.BR_SOLIC_CVE = f.BR_SOLIC_CVE
  AND a.BR_TIPO = f.BR_TIPO
  LEFT JOIN VFAC_SDO_CTA_MES_GRPD g
  ON f.BR_RFC = g.CTE_CVE_RFC
)

SELECT
  DATE_TRUNC(BR_FCH_APE, MONTH) AS MES,
  CASE 
    WHEN (DecisionActual='APPROVE' OR BR_REGLA_DES LIKE "%SCORE%" OR BR_REGLA_DES LIKE "%CONSULTA%"OR BR_REGLA_DES LIKE "%CUTOFF%"OR BR_REGLA_DES LIKE "%APROB%" OR BR_REGLA_DES='RL_EDAD24SBBDEPHIT' OR BR_REGLA_DES='RL_MOP5_6M' OR BR_REGLA_DES='RL_TL_NUM_CTAS_REV_ABT') 
      AND DecisionVISA='APPROVE' AND (CTA_VISA=-999 OR CTA_VISA IS NULL OR FchAlta_VISA<BR_FCH_APE)
      AND DecisionTD='APPROVE' AND (CTA_TD=-999 OR CTA_TD IS NULL OR FchAlta_TD<BR_FCH_APE)
    THEN 'VISA+TD'
     WHEN (DecisionActual='APPROVE' OR BR_REGLA_DES LIKE "%SCORE%" OR BR_REGLA_DES LIKE "%CONSULTA%"OR BR_REGLA_DES LIKE "%CUTOFF%"OR BR_REGLA_DES LIKE "%APROB%" OR BR_REGLA_DES='RL_EDAD24SBBDEPHIT' OR BR_REGLA_DES='RL_MOP5_6M' OR BR_REGLA_DES='RL_TL_NUM_CTAS_REV_ABT') 
      AND DecisionVISA='APPROVE' AND (CTA_VISA=-999 OR CTA_VISA IS NULL OR FchAlta_VISA<BR_FCH_APE)
    THEN 'VISA' 
     WHEN (DecisionActual='APPROVE' OR BR_REGLA_DES LIKE "%SCORE%" OR BR_REGLA_DES LIKE "%CONSULTA%"OR BR_REGLA_DES LIKE "%CUTOFF%"OR BR_REGLA_DES LIKE "%APROB%" OR BR_REGLA_DES='RL_EDAD24SBBDEPHIT' OR BR_REGLA_DES='RL_MOP5_6M' OR BR_REGLA_DES='RL_TL_NUM_CTAS_REV_ABT'OR BR_REGLA_DES LIKE "%NOHIT%") 
      AND DecisionTD='APPROVE' AND (CTA_TD=-999 OR CTA_TD IS NULL OR FchAlta_TD<BR_FCH_APE)
    THEN 'TD' 
     WHEN (DecisionActual='APPROVE' OR BR_REGLA_DES LIKE "%SCORE%" OR BR_REGLA_DES LIKE "%CONSULTA%"OR BR_REGLA_DES LIKE "%CUTOFF%"OR BR_REGLA_DES LIKE "%APROB%" OR BR_REGLA_DES='RL_EDAD24SBBDEPHIT' OR BR_REGLA_DES='RL_MOP5_6M' OR BR_REGLA_DES='RL_TL_NUM_CTAS_REV_ABT' OR BR_REGLA_DES LIKE "%QUASH%"OR BR_REGLA_DES LIKE "%NOHIT%") 
      AND DecisionMinipagos='APPROVE' AND (CTA_Minipagos=-999 OR CTA_Minipagos IS NULL OR FchAlta_Minipagos<BR_FCH_APE)
    THEN 'Minipagos' 
     WHEN (DecisionActual='APPROVE' OR BR_REGLA_DES LIKE "%SCORE%" OR BR_REGLA_DES LIKE "%CONSULTA%"OR BR_REGLA_DES LIKE "%CUTOFF%"OR BR_REGLA_DES LIKE "%APROB%" OR BR_REGLA_DES='RL_EDAD24SBBDEPHIT' OR BR_REGLA_DES='RL_MOP5_6M' OR BR_REGLA_DES='RL_TL_NUM_CTAS_REV_ABT' OR BR_REGLA_DES LIKE "%QUASH%"OR BR_REGLA_DES LIKE "%NOHIT%" OR BR_REGLA_DES LIKE "NOHIT")
    THEN 'Garantizada'
    ELSE 'Rechazado'
  END AS ESCENARIO,
  -- BR_REGLA_DES,
  COUNT(*) AS n 
FROM CONSOLIDADO
WHERE BR_ORG IN (200,210,230)
AND BR_TIPO IN (1010,1020,1030)
GROUP BY 1,2
